{
  "name": "mcp-contract-security",
  "version": "0.1.1",
  "mcpName": "io.github.mastrophot/contract-security-scanner",
  "description": "MCP server for smart contract security scanning with NEAR security model comparisons",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-contract-security": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "deliverables"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "check": "npm run build && npm run test",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "security",
    "smart-contract",
    "near",
    "audit"
  ],
  "author": "Mastrophot",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mastrophot/near-mcp-contract-security.git"
  },
  "homepage": "https://github.com/mastrophot/near-mcp-contract-security#readme",
  "bugs": {
    "url": "https://github.com/mastrophot/near-mcp-contract-security/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
